{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "policy_map",
  "type": "object",
  "required": ["case_id", "indication_category", "modality", "criteria", "overall_signal", "passage_ids_used"],
  "additionalProperties": false,
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "indication_category": { "type": "string", "minLength": 1 },
    "modality": { "type": "string", "minLength": 1 },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["passage_id", "criterion_text", "status", "evidence_ref"],
        "additionalProperties": false,
        "properties": {
          "passage_id": { "type": "string", "minLength": 1 },
          "criterion_text": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["met", "unmet", "ambiguous"] },
          "evidence_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "overall_signal": {
      "type": "string",
      "enum": ["meets_criteria", "does_not_meet", "ambiguous"]
    },
    "passage_ids_used": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
