# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Virtualenvs
.spike-venv/
.venv/
venv/

# Local Claude settings
.claude/settings.local.json

# Runtime audit logs (regenerated on every eval run)
decision_log/

# Local Chroma index (rebuild via rag/build_index.py — binary, regenerable)
.chroma/
chroma_db/

# Eval run artifacts (timestamped reports + JSON companions + run logs).
# Local run records; regenerable. The diff/trend view reads the JSON locally.
eval/results/
*.log

# Physician queue runtime state (regenerated; gitignored like decision_log)
physician_queue/state.json
physician_queue/state.json.tmp

# Secrets — never commit
.env
.env.*
!.env.example

# JWS signing keys (private key only; public key is committed)
config/private_key.pem
