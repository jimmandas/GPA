# GPA v4 — environment variables
# Copy to .env and populate. .env is gitignored; .env.example is committed.
#
# Both keys are read by Python entry points via `from dotenv import load_dotenv`
# at the top of save_report.py, runner.py, diagnose_*.py, and api/main.py.

# Anthropic API key. Used by agents/policy_mapper (direct anthropic SDK per ADR-010).
# Required outside Cowork's managed proxy. Inside Cowork, ANTHROPIC_BASE_URL
# routes through Cowork's session and this can be left empty.
ANTHROPIC_API_KEY=

# OpenAI API key. Used by eval/rationale_judge (GPT-4o judge for the
# faithfulness dim; cross-vendor by scope §7 design). Required for any
# live eval run — without it, rationale_faithfulness reports N/A with a
# clear note ("missing_api_key").
OPENAI_API_KEY=
